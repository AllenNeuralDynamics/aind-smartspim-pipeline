// Lightweight Nextflow config used by CI (stub tests and integration tests).
// Does not require Singularity or real HPC resources.

process {
    executor = 'local'
    // withName selector overrides script-level directives (bare cpus/memory don't)
    withName: '.*' {
        cpus   = 1
        memory = '1 GB'
        time   = '10m'
    }
    withLabel: 'gpu' {
        containerOptions = ''
        clusterOptions   = ''
    }
}

singularity.enabled = false
docker.enabled      = false

profiles {
    // Used by .github/workflows/ci.yml for stub (Tier 1) tests.
    ci {
        process.executor = 'local'
    }

    // Used by .github/workflows/integration.yml on a self-hosted GPU runner.
    // Requires Singularity and a SLURM partition named 'gpu'.
    slurm_ci {
        process.executor = 'slurm'
        process.queue    = 'gpu'
        singularity {
            enabled  = true
            platform = 'linux/amd64'
            envWhitelist = ['SLURM_JOBID', 'SLURM_JOB_CPUS_PER_NODE', 'SLURM_JOB_GPUS']
        }
    }
}
